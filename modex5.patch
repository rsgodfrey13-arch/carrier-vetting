   .row { grid-template-columns: minmax(0, 1fr) minmax(0, 1.4fr); }
   dd { text-align: left; }
 }
 
 @media (max-width: 600px) {
   .page { padding-inline: 14px; }
   .carrier-header { padding-inline: 16px; }
   .info-card { padding-inline: 14px; }
 }
 
