+.form-grid label {
+  display: block;
+  font-size: 12px;
+  color: #9eb0d3;
+  margin-bottom: 5px;
+}
+
+.form-grid input,
+.form-grid select,
+.form-grid textarea {
+  width: 100%;
+  border-radius: 10px;
