+.insurance-review-page {
+  min-height: 100vh;
+}
+
+.review-shell {
+  width: min(1180px, calc(100% - 32px));
+  margin: 28px auto 56px;
+  position: relative;
+  z-index: 1;
+}
+
+.review-header {
+  display: flex;
+  justify-content: space-between;
+  align-items: center;
+  gap: 16px;
+  margin-bottom: 14px;
+}
+
+.review-header h1 {
+  margin: 0;
+  color: #e7eefb;
+}
+
+.review-header p {
+  margin: 6px 0 0;
+  color: #9eb0d3;
+}
+
+.review-card {
+  background: rgba(8, 18, 36, 0.86);
+  border: 1px solid rgba(124, 146, 196, 0.18);
+  border-radius: 16px;
+  backdrop-filter: blur(8px);
+  overflow: hidden;
+}
+
+.status-banner {
+  padding: 11px 14px;
+  font-size: 14px;
+  border-bottom: 1px solid rgba(124, 146, 196, 0.2);
+}
+
+.status-banner.is-error {
+  color: #ffd5d5;
+  background: rgba(190, 42, 56, 0.25);
+}
+
+.status-banner.is-success {
+  color: #d4f8e9;
+  background: rgba(28, 136, 87, 0.22);
+}
+
+.table-wrap {
+  overflow-x: auto;
+}
+
+.review-table {
+  width: 100%;
+  border-collapse: collapse;
+}
+
+.review-table th,
+.review-table td {
+  padding: 12px 14px;
+  text-align: left;
+  vertical-align: top;
+  border-bottom: 1px solid rgba(124, 146, 196, 0.14);
+}
+
+.review-table th {
+  color: #9eb0d3;
+  font-size: 12px;
+  letter-spacing: 0.04em;
+  text-transform: uppercase;
+}
+
+.review-table td {
+  color: #e7eefb;
+  font-size: 14px;
+}
+
+.review-table .actions {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 8px;
+}
+
+.btn-inline {
+  border: 1px solid rgba(124, 146, 196, 0.3);
+  background: rgba(13, 28, 52, 0.7);
+  color: #e7eefb;
+  border-radius: 10px;
+  padding: 6px 10px;
+  font-size: 13px;
+  cursor: pointer;
+}
+
+.btn-inline:hover {
+  border-color: rgba(124, 146, 196, 0.65);
+}
+
+.btn-inline.is-danger {
+  border-color: rgba(209, 80, 102, 0.45);
+  color: #ffd2dc;
+}
+
+.resolve-row td {
+  background: rgba(13, 26, 48, 0.65);
+}
+
+.resolve-panel {
+  padding: 6px 2px;
+}
+
+.form-grid {
+  display: grid;
