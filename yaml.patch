+++ b/openapi.yaml
@@ -0,0 +1,1756 @@
+openapi: 3.0.3
+info:
+  title: CarrierShark API v1
+  version: 1.0.0
+  description: |
+    The CarrierShark API allows companies to monitor carriers, receive compliance alerts, and manage digital carrier contracts.
+
+    Base URL:
+    https://carriershark.com/api/v1
+
+    Authentication:
+    All endpoints require a company API key.
+
+    Authorization header format:
+
+    Authorization: Bearer cs_live_your_api_key
+
+    Test key example:
+    cs_test_123456789
+  contact:
+    name: CarrierShark Support
+    email: support@carriershark.com
+    url: https://carriershark.com
+  license:
+    name: Proprietary
+servers:
+  - url: https://carriershark.com/api/v1
+    description: Production v1 API
+security:
+  - bearerAuth: []
+tags:
+  - name: Carriers
+    description: Carrier lookup and company carrier management endpoints.
+  - name: Alerts
+    description: Alert retrieval and alert state mutation endpoints.
+  - name: Contracts
+    description: Contract retrieval and contract state mutation endpoints.
+  - name: Imports
+    description: Carrier import limit and bulk import endpoints.
+paths:
+  /me/carriers/import-limits:
+    get:
+      tags: [Imports]
+      summary: Get import limits and current usage
+      description: |
+        Returns the authenticated company's carrier import plan limits and current saved-carrier usage.
+        Use this endpoint before bulk imports to understand total capacity and per-import caps.
+      operationId: getCarrierImportLimits
+      responses:
+        '200':
+          description: Import limits loaded successfully.
+          headers:
+            X-RateLimit-Limit:
+              $ref: '#/components/headers/X-RateLimit-Limit'
+            X-RateLimit-Remaining:
+              $ref: '#/components/headers/X-RateLimit-Remaining'
+            X-RateLimit-Reset:
+              $ref: '#/components/headers/X-RateLimit-Reset'
+          content:
+            application/json:
+              schema:
+                type: object
+                required: [plan, max_total, max_per_import, chunk_size, current_total]
+                properties:
+                  plan:
+                    type: string
+                  max_total:
+                    type: integer
+                  max_per_import:
+                    type: integer
+                  chunk_size:
+                    type: integer
+                  current_total:
+                    type: integer
+        '401':
+          $ref: '#/components/responses/UnauthorizedError'
+        '429':
+          description: Rate limit exceeded
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/Error'
+              example:
+                error: Rate limit exceeded
+        '500':
+          description: Failed to load import limits.
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/Error'
+              example:
+                error: Failed to load import limits
+
+  /me/carriers/import:
+    post:
+      tags: [Imports]
+      summary: Bulk import carriers into the authenticated company account
+      description: |
+        Imports multiple carrier DOT numbers into the authenticated company's saved carrier list.
+        The API normalizes DOT values, enforces per-import and plan-level limits, and reports invalid or skipped entries.
+      operationId: importCarriers
+      requestBody:
+        required: true
+        content:
+          application/json:
+            schema:
+              type: object
+              required: [dots]
+              properties:
+                dots:
+                  type: array
+                  description: Array of DOT numbers to import.
+                  items:
+                    type: string
+            examples:
+              bulkImport:
+                value:
+                  dots: ["336075", "123456"]
+      responses:
+        '200':
+          description: Import was processed.
+          headers:
+            X-RateLimit-Limit:
+              $ref: '#/components/headers/X-RateLimit-Limit'
+            X-RateLimit-Remaining:
+              $ref: '#/components/headers/X-RateLimit-Remaining'
+            X-RateLimit-Reset:
+              $ref: '#/components/headers/X-RateLimit-Reset'
+          content:
+            application/json:
+              schema:
+                type: object
+                required:
+                  - received
+                  - valid_unique
+                  - attempted
+                  - inserted
+                  - already_had
+                  - rejected_due_to_import_limit
+                  - rejected_due_to_plan_limit
+                  - invalid_count
+                  - invalid_sample
+                properties:
+                  received:
+                    type: integer
+                  valid_unique:
+                    type: integer
+                  attempted:
+                    type: integer
+                  inserted:
+                    type: integer
+                  already_had:
+                    type: integer
+                  rejected_due_to_import_limit:
+                    type: integer
+                  rejected_due_to_plan_limit:
+                    type: integer
+                  invalid_count:
+                    type: integer
+                  invalid_sample:
+                    type: array
+                    items:
+                      type: string
+        '401':
+          $ref: '#/components/responses/UnauthorizedError'
+        '429':
+          description: Rate limit exceeded
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/Error'
+              example:
+                error: Rate limit exceeded
+        '500':
+          description: Failed to import carriers.
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/Error'
+              example:
+                error: Failed to import carriers
+
+  /carriers:
+    get:
+      tags: [Carriers]
+      summary: Search carriers
+      description: |
+        Search the carrier database using DOT, MC, legal name, DBA name, or location filters.
+        At least one search parameter must be provided.
+      operationId: searchCarriers
+      parameters:
+        - $ref: '#/components/parameters/DotQuery'
+        - name: mc
+          in: query
+          schema:
+            type: string
+        - name: legalname
+          in: query
+          schema:
+            type: string
+        - name: dbaname
+          in: query
+          schema:
+            type: string
+        - name: city
+          in: query
+          schema:
+            type: string
+        - name: state
+          in: query
+          schema:
+            type: string
+        - $ref: '#/components/parameters/PageQuery'
+        - $ref: '#/components/parameters/PageSizeQuery'
+      responses:
+        '200':
+          description: Carrier search results.
+          headers:
+            X-RateLimit-Limit:
+              $ref: '#/components/headers/X-RateLimit-Limit'
+            X-RateLimit-Remaining:
+              $ref: '#/components/headers/X-RateLimit-Remaining'
+            X-RateLimit-Reset:
+              $ref: '#/components/headers/X-RateLimit-Reset'
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/CarrierSearchResponse'
+              example:
+                rows:
+                  - dot: "336075"
+                    legalname: ACME TRANSPORT LLC
+                    dbaname: ACME LOGISTICS
+                    city: DALLAS
+                    state: TX
+                    allowedtooperate: AUTHORIZED
+                    safetyrating: SATISFACTORY
+                total: 1
+                page: 1
+                pageSize: 25
+        '400':
+          description: No search filters were supplied.
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/Error'
+              example:
+                error: At least one search parameter is required (dot, mc, legalname, dbaname, city, state)
+        '429':
+          description: Rate limit exceeded
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/Error'
+              example:
+                error: Rate limit exceeded
+        '500':
+          description: Search failed.
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/Error'
+              example:
+                error: Search failed
+
+  /carriers/{dot}:
+    get:
+      tags: [Carriers]
+      summary: Get a carrier by DOT number
+      description: |
+        Returns a single carrier record for the provided USDOT number.
+        The response includes carrier table fields plus a derived `cargo_carried` array when cargo data exists.
+      operationId: getCarrierByDot
+      parameters:
+        - $ref: '#/components/parameters/DotPath'
+      responses:
+        '200':
+          description: Carrier record with cargo information.
+          headers:
+            X-RateLimit-Limit:
+              $ref: '#/components/headers/X-RateLimit-Limit'
+            X-RateLimit-Remaining:
+              $ref: '#/components/headers/X-RateLimit-Remaining'
+            X-RateLimit-Reset:
+              $ref: '#/components/headers/X-RateLimit-Reset'
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/CarrierDetail'
+        '404':
+          description: Carrier not found.
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/Error'
+              example:
+                error: Carrier not found
+        '429':
+          description: Rate limit exceeded
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/Error'
+              example:
+                error: Rate limit exceeded
+        '500':
+          description: Database query failed.
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/Error'
+              example:
+                error: Database query failed
+
+  /me/carriers:
+    get:
+      tags: [Carriers]
+      summary: List carriers saved by the authenticated company
+      description: |
+        Lists the carriers already saved for the authenticated company.
+        Supports the same filtering and pagination pattern as the public carrier search endpoint.
+      operationId: listMyCarriers
+      parameters:
+        - $ref: '#/components/parameters/DotQuery'
+        - name: mc
+          in: query
+          schema:
+            type: string
+        - name: legalname
+          in: query
+          schema:
+            type: string
+        - name: dbaname
+          in: query
+          schema:
+            type: string
+        - name: city
+          in: query
+          schema:
+            type: string
+        - name: state
+          in: query
+          schema:
+            type: string
+        - $ref: '#/components/parameters/PageQuery'
+        - $ref: '#/components/parameters/PageSizeQuery'
+      responses:
+        '200':
+          description: Saved carriers list.
+          headers:
+            X-RateLimit-Limit:
+              $ref: '#/components/headers/X-RateLimit-Limit'
+            X-RateLimit-Remaining:
+              $ref: '#/components/headers/X-RateLimit-Remaining'
+            X-RateLimit-Reset:
+              $ref: '#/components/headers/X-RateLimit-Reset'
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/MyCarrierListResponse'
+              example:
+                rows:
+                  - dot: "336075"
+                    legalname: ACME TRANSPORT LLC
+                    dbaname: ACME LOGISTICS
+                    city: DALLAS
+                    state: TX
+                    allowedtooperate: AUTHORIZED
+                    safetyrating: SATISFACTORY
+                    added_at: '2026-03-01T14:25:00Z'
+                total: 1
+                page: 1
+                pageSize: 25
+        '401':
+          $ref: '#/components/responses/UnauthorizedError'
+        '429':
+          description: Rate limit exceeded
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/Error'
+              example:
+                error: Rate limit exceeded
+        '500':
+          description: Failed to load company carriers.
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/Error'
+              example:
+                error: Failed to load company carriers
+    post:
+      tags: [Carriers]
+      summary: Save one or more carriers for the authenticated company
+      description: |
+        Saves one or more carrier DOT numbers for the authenticated company.
+        DOT values are normalized, checked against the carriers table, and reported as inserted, already saved, or invalid.
+      operationId: addMyCarriers
+      requestBody:
+        required: true
+        content:
+          application/json:
+            schema:
+              type: object
+              required: [dot]
+              properties:
+                dot:
+                  oneOf:
+                    - type: string
+                    - type: array
+                      items:
+                        type: string
+            examples:
+              single:
+                value:
+                  dot: "336075"
+              multiple:
+                value:
+                  dot: ["336075", "123456"]
+      responses:
+        '200':
+          description: Carrier save attempt results.
+          headers:
+            X-RateLimit-Limit:
+              $ref: '#/components/headers/X-RateLimit-Limit'
+            X-RateLimit-Remaining:
+              $ref: '#/components/headers/X-RateLimit-Remaining'
+            X-RateLimit-Reset:
+              $ref: '#/components/headers/X-RateLimit-Reset'
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/CarrierMutationResponse'
+        '400':
+          description: The request body omitted DOT values or none were valid.
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/Error'
+              examples:
+                dotRequired:
+                  value:
+                    error: dot is required
+                noValidDots:
+                  value:
+                    error: No valid DOT numbers provided
+        '401':
+          $ref: '#/components/responses/UnauthorizedError'
+        '429':
+          description: Rate limit exceeded
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/Error'
+              example:
+                error: Rate limit exceeded
+        '500':
+          description: Failed to add carriers.
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/Error'
+              example:
+                error: Failed to add carriers
+    delete:
+      tags: [Carriers]
+      summary: Remove one or more saved carriers for the authenticated company
+      description: |
+        Removes one or more saved carriers from the authenticated company's list.
+        Each submitted DOT is reported individually as deleted or not found.
+      operationId: deleteMyCarriers
+      requestBody:
+        required: true
+        content:
+          application/json:
+            schema:
+              type: object
+              required: [dot]
+              properties:
+                dot:
+                  oneOf:
+                    - type: string
+                    - type: array
+                      items:
+                        type: string
+            examples:
+              single:
+                value:
+                  dot: "336075"
+              multiple:
+                value:
+                  dot: ["336075", "123456"]
+      responses:
+        '200':
+          description: Carrier delete attempt results.
+          headers:
+            X-RateLimit-Limit:
+              $ref: '#/components/headers/X-RateLimit-Limit'
+            X-RateLimit-Remaining:
+              $ref: '#/components/headers/X-RateLimit-Remaining'
+            X-RateLimit-Reset:
+              $ref: '#/components/headers/X-RateLimit-Reset'
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/CarrierDeleteResponse'
+        '400':
+          description: The request body omitted DOT values or none were valid.
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/Error'
+              examples:
+                dotRequired:
+                  value:
+                    error: dot is required
+                noValidDots:
+                  value:
+                    error: No valid DOT numbers provided
+        '401':
+          $ref: '#/components/responses/UnauthorizedError'
+        '429':
+          description: Rate limit exceeded
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/Error'
+              example:
+                error: Rate limit exceeded
+        '500':
+          description: Failed to remove carriers.
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/Error'
+              example:
+                error: Failed to remove carriers
+
+  /carriers/{dot}/alerts:
+    get:
+      tags: [Alerts]
+      summary: List alerts for a specific carrier
+      description: |
+        Returns API-channel alerts for a specific carrier DOT belonging to the authenticated company.
+        Error-state alerts are excluded, and results can be filtered by alert ID and status.
+      operationId: listCarrierAlerts
+      parameters:
+        - $ref: '#/components/parameters/DotPath'
+        - name: id
+          in: query
+          schema:
+            type: string
+          description: Alert identifier.
+        - name: status
+          in: query
+          schema:
+            type: string
+          description: Alert status filter.
+        - $ref: '#/components/parameters/PageQuery'
+        - $ref: '#/components/parameters/PageSizeQuery'
+      responses:
+        '200':
+          description: Alert list for the carrier.
+          headers:
+            X-RateLimit-Limit:
+              $ref: '#/components/headers/X-RateLimit-Limit'
+            X-RateLimit-Remaining:
+              $ref: '#/components/headers/X-RateLimit-Remaining'
+            X-RateLimit-Reset:
+              $ref: '#/components/headers/X-RateLimit-Reset'
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/AlertListResponse'
+        '401':
+          $ref: '#/components/responses/UnauthorizedError'
+        '429':
+          description: Rate limit exceeded
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/Error'
+              example:
+                error: Rate limit exceeded
+        '500':
+          description: Failed to load carrier alerts.
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/Error'
+              example:
+                error: Failed to load carrier alerts
+
+  /alerts:
+    get:
+      tags: [Alerts]
+      summary: List alerts
+      description: |
+        Returns API-channel alerts for the authenticated company across all tracked carriers.
+        Error-state alerts are excluded, and results can be filtered by alert ID, status, and DOT number.
+      operationId: listAlerts
+      parameters:
+        - name: id
+          in: query
+          schema:
+            type: string
+        - name: status
+          in: query
+          schema:
+            type: string
+        - name: dotnumber
+          in: query
+          schema:
+            type: string
+        - $ref: '#/components/parameters/PageQuery'
+        - $ref: '#/components/parameters/PageSizeQuery'
+      responses:
+        '200':
+          description: Alert list.
+          headers:
+            X-RateLimit-Limit:
+              $ref: '#/components/headers/X-RateLimit-Limit'
+            X-RateLimit-Remaining:
+              $ref: '#/components/headers/X-RateLimit-Remaining'
+            X-RateLimit-Reset:
+              $ref: '#/components/headers/X-RateLimit-Reset'
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/AlertListResponse'
+              example:
+                rows:
+                  - info:
+                      alert_id: 46
+                      event_id: evt_12345
+                      event_type: carrier.updated
+                      dotnumber: "336075"
+                      occurred_at: '2026-03-15T10:15:00Z'
+                      status: NEW
+                      created_at: '2026-03-15T10:16:00Z'
+                    changes:
+                      allowedtooperate:
+                        old: INACTIVE
+                        new: AUTHORIZED
+                    carrier:
+                      dotnumber: "336075"
+                      legalname: ACME TRANSPORT LLC
+                total: 1
+                page: 1
+                pageSize: 25
+        '401':
+          $ref: '#/components/responses/UnauthorizedError'
+        '429':
+          description: Rate limit exceeded
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/Error'
+              example:
+                error: Rate limit exceeded
+        '500':
+          description: Failed to load alerts.
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/Error'
+              example:
+                error: Failed to load alerts
+
+  /alerts/new:
+    get:
+      tags: [Alerts]
+      summary: List new alerts only
+      description: |
+        Returns only alerts in `NEW` status for the authenticated company.
+        Use this endpoint to poll for unprocessed alert activity.
+      operationId: listNewAlerts
+      parameters:
+        - name: id
+          in: query
+          schema:
+            type: string
+        - name: dotnumber
+          in: query
+          schema:
+            type: string
+        - $ref: '#/components/parameters/PageQuery'
+        - $ref: '#/components/parameters/PageSizeQuery'
+      responses:
+        '200':
+          description: New alert list.
+          headers:
+            X-RateLimit-Limit:
+              $ref: '#/components/headers/X-RateLimit-Limit'
+            X-RateLimit-Remaining:
+              $ref: '#/components/headers/X-RateLimit-Remaining'
+            X-RateLimit-Reset:
+              $ref: '#/components/headers/X-RateLimit-Reset'
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/AlertListResponse'
+        '401':
+          $ref: '#/components/responses/UnauthorizedError'
+        '429':
+          description: Rate limit exceeded
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/Error'
+              example:
+                error: Rate limit exceeded
+        '500':
+          description: Failed to load NEW alerts.
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/Error'
+              example:
+                error: Failed to load NEW alerts
+
+  /alerts/processed:
+    patch:
+      tags: [Alerts]
+      summary: Mark alerts as processed
+      description: |
+        Marks one or more API-channel alerts as `PROCESSED` for the authenticated company.
+        Only matching alert IDs owned by the company are updated.
+      operationId: markAlertsProcessed
+      requestBody:
+        required: true
+        content:
+          application/json:
+            schema:
+              type: object
+              required: [alerts]
+              properties:
+                alerts:
+                  type: array
+                  items:
+                    type: string
+                  description: Numeric alert IDs.
+            example:
+              alerts: ["46", "47"]
+      responses:
+        '200':
+          description: Alert update results.
+          headers:
+            X-RateLimit-Limit:
+              $ref: '#/components/headers/X-RateLimit-Limit'
+            X-RateLimit-Remaining:
+              $ref: '#/components/headers/X-RateLimit-Remaining'
+            X-RateLimit-Reset:
+              $ref: '#/components/headers/X-RateLimit-Reset'
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/AlertMutationResponse'
+        '400':
+          description: No valid numeric alert IDs were supplied.
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/Error'
+              example:
+                error: alerts array is required (numeric ids)
+        '401':
+          $ref: '#/components/responses/UnauthorizedError'
+        '429':
+          description: Rate limit exceeded
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/Error'
+              example:
+                error: Rate limit exceeded
+        '500':
+          description: Failed to mark alerts processed.
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/Error'
+              example:
+                error: Failed to mark alerts processed
+
+  /alerts/unprocessed:
+    patch:
+      tags: [Alerts]
+      summary: Mark alerts as unprocessed
+      description: |
+        Reverts one or more API-channel alerts back to `NEW` status for the authenticated company.
+        Only matching alert IDs owned by the company are updated.
+      operationId: markAlertsUnprocessed
+      requestBody:
+        required: true
+        content:
+          application/json:
+            schema:
+              type: object
+              required: [alerts]
+              properties:
+                alerts:
+                  type: array
+                  items:
+                    type: string
+                  description: Numeric alert IDs.
+            example:
+              alerts: ["46", "47"]
+      responses:
+        '200':
+          description: Alert update results.
+          headers:
+            X-RateLimit-Limit:
+              $ref: '#/components/headers/X-RateLimit-Limit'
+            X-RateLimit-Remaining:
+              $ref: '#/components/headers/X-RateLimit-Remaining'
+            X-RateLimit-Reset:
+              $ref: '#/components/headers/X-RateLimit-Reset'
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/AlertMutationResponse'
+        '400':
+          description: No valid numeric alert IDs were supplied.
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/Error'
+              example:
+                error: alerts array is required (numeric ids)
+        '401':
+          $ref: '#/components/responses/UnauthorizedError'
+        '429':
+          description: Rate limit exceeded
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/Error'
