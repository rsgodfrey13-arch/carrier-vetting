 async function getCurrentUserBillingStateByUserId(pool, userId) {
   const { rows } = await pool.query(
     `
     SELECT plan, subscription_status
     FROM users
     WHERE id = $1
     LIMIT 1
     `,
     [userId]
   );
 
   return rows[0] || null;
 }
 
