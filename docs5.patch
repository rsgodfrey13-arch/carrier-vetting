       const siteHeader = document.getElementById('site-header');
       const getOffset = () => (siteHeader ? Math.round(siteHeader.getBoundingClientRect().height) + 16 : 16);
       const scrollToHash = (hash) => {
         if (!hash) return false;
         const target = document.getElementById(hash) || document.querySelector(`[data-section-id="${hash}"]`) || document.querySelector(`[id="${hash}"]`);
         if (!target) return false;
         const targetTop = window.scrollY + target.getBoundingClientRect().top - getOffset();
         window.scrollTo({ top: Math.max(targetTop, 0), behavior: 'smooth' });
         return true;
       };
 
       requestAnimationFrame(() => {
         if (window.location.hash) {
           scrollToHash(decodeURIComponent(window.location.hash.slice(1)));
         }
       });
 
