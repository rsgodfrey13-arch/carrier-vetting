+function normalizeDocumentReviewAction(v) {
+  const x = String(v || "").toUpperCase().trim();
+  if (x === "SAVE_COVERAGE" || x === "CLOSE") return x;
+  throw new Error("action must be SAVE_COVERAGE or CLOSE.");
