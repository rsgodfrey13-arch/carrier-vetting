 }
 
 function normalizeCoverageType(v) {
   const x = String(v || "").toUpperCase().trim();
   const allowed = new Set([
     "AUTO_LIABILITY",
     "CARGO",
     "GENERAL_LIABILITY",
     "UMBRELLA_LIABILITY",
     "WORKERS_COMP",
     "ERRORS_OMISSIONS",
