+    if (op === "NOT_EQUALS") return `Carrier is flagged if ${label} is not ${value}.`;
+    return `Carrier is flagged if ${label} is ${value}.`;
+  }
+
+  return `Carrier is flagged if ${label} matches this rule.`;
+}
