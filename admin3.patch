diff --git a/static/css/admin-insurance-document-review.css b/static/css/admin-insurance-document-review.css
index d958642c7307f1c96f49452d3f30a0d7c127aa30..5ea9a026aa558cff96e368a166a8e73fbda8d152 100644
--- a/static/css/admin-insurance-document-review.css
+++ b/static/css/admin-insurance-document-review.css
@@ -110,86 +110,112 @@
 }
 
 .btn-inline {
   border: 1px solid rgba(124, 146, 196, 0.3);
   background: rgba(13, 28, 52, 0.7);
   color: #e7eefb;
   border-radius: 10px;
   padding: 6px 10px;
   font-size: 13px;
   cursor: pointer;
 }
 
 .btn-inline:hover {
   border-color: rgba(124, 146, 196, 0.65);
 }
 
 .btn-inline.is-danger {
   border-color: rgba(209, 80, 102, 0.45);
   color: #ffd2dc;
 }
 
 .resolve-row td {
   background: rgba(13, 26, 48, 0.65);
 }
 
+
 .resolve-panel {
-  padding: 6px 2px;
+  padding: 10px 6px;
+  overflow-x: clip;
+}
+
+.doc-form-grid {
+  grid-template-columns: repeat(5, minmax(0, 1fr));
+  gap: 12px;
 }
 
 .form-grid {
   display: grid;
   gap: 10px;
   grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
 }
 
 .form-grid label {
   display: block;
   font-size: 12px;
   color: #9eb0d3;
   margin-bottom: 5px;
 }
 
 .form-grid input,
 .form-grid select,
 .form-grid textarea {
   width: 100%;
   border-radius: 10px;
   border: 1px solid rgba(124, 146, 196, 0.3);
   background: rgba(8, 18, 36, 0.8);
   color: #e7eefb;
   padding: 9px 10px;
   font-size: 14px;
 }
 
 .form-grid textarea {
   min-height: 74px;
   resize: vertical;
 }
 
 .panel-actions {
   margin-top: 10px;
   display: flex;
   gap: 10px;
 }
 
 .empty-state {
   color: #9eb0d3;
   padding: 22px 14px;
   text-align: center;
 }
 
 .review-table .muted {
   color: #9eb0d3;
   font-size: 12px;
 }
 
+
+@media (max-width: 1180px) {
+  .doc-form-grid {
+    grid-template-columns: repeat(3, minmax(0, 1fr));
+  }
+}
+
+@media (max-width: 760px) {
+  .doc-form-grid {
+    grid-template-columns: repeat(2, minmax(0, 1fr));
+  }
+}
+
+@media (max-width: 520px) {
+  .doc-form-grid {
+    grid-template-columns: 1fr;
+  }
+}
+
 @media (max-width: 860px) {
   .review-shell {
     width: calc(100% - 20px);
   }
 
   .review-header {
     flex-direction: column;
     align-items: flex-start;
   }
 }
